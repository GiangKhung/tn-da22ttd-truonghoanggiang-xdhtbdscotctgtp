{
  "expo": {
    "name": "Gara Trường Phát",
    "slug": "gara-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "garamobile",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.garatruongphat.mobile"
    },
    "android": {
      "package": "com.garatruongphat.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "color": "#0f172a"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
