# Bỏ qua thư mục node_modules cục bộ (Docker sẽ tự cài đặt lại bên trong container)
node_modules
**/node_modules

# Bỏ qua các file build và cache cục bộ
.next
out
.expo
.vscode

# Bỏ qua phân hệ di động (không cần thiết để build web server)
mobile

