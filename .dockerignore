.env
.env.local
*.db
*.db-journal

# Bỏ qua Git và các file tài liệu đồ án, báo cáo
.git
.gitignore
.agents
AGENTS.md
CLAUDE.md
*.docx
*.pdf
*.pptx
poster.html
slides.html

