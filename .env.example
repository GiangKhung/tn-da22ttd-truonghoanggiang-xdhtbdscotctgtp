# URL kết nối cơ sở dữ liệu (Mặc định dùng SQLite cục bộ cho môi trường phát triển)
DATABASE_URL="file:./dev.db"

# Khóa bí mật dùng để ký mã xác thực JWT (Mã JSON Web Token) cho đăng nhập người dùng và kỹ thuật viên.
# Có thể tạo chuỗi ngẫu nhiên bằng lệnh: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="your_jwt_secret_key_here"

# Khóa API của Google Gemini để sử dụng tính năng chẩn đoán lỗi xe bằng trí tuệ nhân tạo (AI Assistant)
# Lấy khóa miễn phí từ Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY="AIzaSyYourGeminiApiKeyHere"

# Khóa API dự phòng cho mô hình AI tự do (nếu sử dụng)
FREEMODEL_API_KEY="fe_oa_your_fallback_api_key_here"
